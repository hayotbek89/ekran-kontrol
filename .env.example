# GitHub Token for auto-update releases
# Create at: https://github.com/settings/tokens (Personal Access Tokens)
# Requires: repo (full control of private repositories), releases (read/write access to releases)
GH_TOKEN="your_github_personal_access_token_here"

# Gemini API key (optional, for AI features)
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# App URL (optional, for deployment)
APP_URL="MY_APP_URL"
